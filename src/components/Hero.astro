---
interface Props {
  title: string;
  subtitle?: string;
  text?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title,
  subtitle,
  text,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel
} = Astro.props;
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">{subtitle}</p>
      <h1>{title}</h1>
      {text && <p class="hero-text">{text}</p>}

      <div class="hero-actions">
        {primaryHref && primaryLabel && (
          <a class="button" href={primaryHref}>{primaryLabel}</a>
        )}
        {secondaryHref && secondaryLabel && (
          <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
        )}
      </div>
    </div>
  </div>
</section>