---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Trains and Castles | A Child’s Journey of Trains, Castles, and Wonder"
  description="A child-friendly companion book filled with trains, castles, curiosity, and discovery across England."
>
  <Hero
    title="Trains and Castles"
    subtitle="A child’s-eye journey through trains, castles, cities, and wonder."
  />

  <Section className="book-page">
    <div class="book-layout">
      <img
          src="/covers/trains-castles.jpg"
          alt="Trains and Castles book cover by Jorge R. Obando"
          title="Trains and Castles — Jorge R. Obando"
        />

      <div>
        <p>
          Trains and Castles follows the same journey as The Tracks Remember, but through
          the eyes of a child.
        </p>
        <p>
          With movement, curiosity, and imagination at its center, it invites young readers
          into an adventure shaped by train rides, new places, old stones, big questions,
          and the excitement of seeing the world unfold.
        </p>
        <p>
          It is simple, warm, and full of wonder.
        </p>
      </div>
    </div>
  </Section>

  <Section title="A companion to the journey">
    <p>
      This book was created as a companion to The Tracks Remember, offering a lighter,
      child-friendly way to experience the same path.
    </p>
  </Section>

  <Section title="Explore more">
    <p>
      Continue the experience with bonus content inside the member space.
    </p>
    <a
      class="button"
      href="https://bookmembers.base44.app/members"
    >
      Explore More
    </a>
  </Section>

  <Section title="Find the book">
    <p>Available on Amazon.</p>
    <a
      class="button"
      href="https://a.co/d/08TJjA3Z"
      target="_blank"
      rel="noopener noreferrer"
    >
      View on Amazon
    </a>
  </Section>
</BaseLayout>