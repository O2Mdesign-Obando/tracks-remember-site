---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="The Tracks Remember | A Reflective Journey Across England"
  description="A reflective travel narrative exploring memory, family, and place through a journey across England."
>
  <Hero
    title="The Tracks Remember"
    subtitle="A reflective journey across England, memory, family, and place."
  />

  <Section className="book-page">
    <div class="book-layout">
      <img
          src="/covers/tracks-remember.jpg"
          alt="The Tracks Remember book cover by Jorge R. Obando"
          title="The Tracks Remember — Jorge R. Obando"
        />

      <div>
        <p>
          The Tracks Remember is a calm, reflective travel narrative shaped by movement
          across England and by the inner landscapes that travel awakens.
        </p>
        <p>
          Through trains, cities, coastlines, castles, and quiet moments of family life,
          the book explores the way memory and presence meet—how places can hold meaning,
          how travel can deepen connection, and how a journey can become something greater
          than distance.
        </p>
        <p>
          It is a story of observation, emotion, and return.
        </p>
      </div>
    </div>
  </Section>

  <Section title="Continue the journey">
    <p>
      Go beyond the book with comics, coloring pages, and bonus reflections.
    </p>
    <a
      class="button"
      href="https://bookmembers.base44.app/members"
    >
      Continue the Journey
    </a>
  </Section>

  <Section title="Find the book">
    <p>Available on Amazon.</p>
    <a
      class="button"
      href="https://a.co/d/0hTeRwq2"
      target="_blank"
      rel="noopener noreferrer"
    >
      View on Amazon
    </a>
  </Section>
</BaseLayout>